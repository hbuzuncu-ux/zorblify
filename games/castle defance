    const a=Math.random()*Math.PI*2,spd=Math.random()*3+1;
    parts.push({x,y,vx:Math.cos(a)*spd,vy:Math.sin(a)*spd-0.5,life:1,dec:0.04+Math.random()*0.03,r:2+Math.random()*3,col});
  }
}
function addFloat(text,x,y,col,big=false){
