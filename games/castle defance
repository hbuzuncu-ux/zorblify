function showCombo(){
  const el=document.getElementById('comboPop');
  const labels={2:'COMBO ×2 🔥',3:'COMBO ×3 ⚡',4:'COMBO ×4 💥',5:'MAX ×5 🌟'};
  const lbl=labels[Math.floor(combo)];
  if(!lbl)return;
  el.textContent=lbl; el.style.opacity='1';
