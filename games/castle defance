<script>
// ═══════════════════════════════
// SUPABASE
// ═══════════════════════════════
const SB_URL='https://lscqqfeqpbfmcccifrwj.supabase.co';
const SB_KEY='sb_publishable_HPGXHwa51dk_1nmAqoeoXA_6zCzOVzM';
async function sbReq(path,opts={}){
  const r=await fetch(SB_URL+'/rest/v1/'+path,{
    headers:{'apikey':SB_KEY,'Authorization':'Bearer '+SB_KEY,'Content-Type':'application/json','Prefer':opts.prefer||''},
    ...opts
  });
  if(!r.ok) throw new Error(await r.text());
  return r.status===204?null:r.json();
}
async function saveEndlessScore(name,wave,score){
  try{
    await sbReq('scores',{method:'POST',prefer:'return=minimal',
      body:JSON.stringify({player_name:name,game_id:'castle-defense-endless',level_number:wave,stars:0,moves:score})
    });
  }catch(e){console.warn(e);}
}
async function loadEndlessScores(){
  try{
    return await sbReq('scores?game_id=eq.castle-defense-endless&order=moves.desc&limit=10')||[];
  }catch(e){return[];}
}

// ═══════════════════════════════
// CONSTANTS
// ═══════════════════════════════
const CELL=40;
const COLS=16, ROWS=11;
const CW=COLS*CELL, CH=ROWS*CELL;

const TDEFS={
  archer:{name:'Archer',icon:'🏹',cost:50,dmg:12,range:3.2,rate:55,color:'#fbbf24',aoe:0,slow:0,
    upg:[{dmg:20,range:3.6,rate:42},{dmg:32,range:4,rate:32}]},
  mage:  {name:'Mage',icon:'🔮',cost:75,dmg:28,range:2.8,rate:88,color:'#a78bfa',aoe:0,slow:0.45,
    upg:[{dmg:46,range:3.2,rate:72,slow:0.6},{dmg:72,range:3.8,rate:58,slow:0.72}]},
  cannon:{name:'Cannon',icon:'💣',cost:100,dmg:55,range:2.8,rate:130,color:'#f87171',aoe:1.1,slow:0,
    upg:[{dmg:90,range:3.2,aoe:1.5,rate:105},{dmg:140,range:3.8,aoe:2,rate:80}]},
};

const EDEFS={
  goblin:{name:'Goblin',icon:'👺',hp:30, spd:1.8,reward:4, sz:13,col:'#4ade80'},
  zombie:{name:'Zombie',icon:'🧟',hp:85,spd:0.9,reward:8, sz:16,col:'#86efac'},
  knight:{name:'Knight',icon:'🗡️',hp:260,spd:1.2,reward:14,sz:18,col:'#93c5fd'},
  troll: {name:'Troll', icon:'👹',hp:550,spd:0.6,reward:28,sz:24,col:'#fca5a5'},
  boss:  {name:'BOSS',  icon:'💀',hp:1800,spd:0.45,reward:80,sz:30,col:'#f0c060'},
};

const SPELL_CD={meteor:1800,frost:2200,goldrush:2800};

// ═══════════════════════════════
// LEVEL DEFINITIONS — 30 levels
// ═══════════════════════════════
// Path format: array of [col,row] waypoints — engine interpolates
function mkPath(wps){
  const pts=[];
  for(let i=0;i<wps.length-1;i++){
    const [c1,r1]=wps[i],[c2,r2]=wps[i+1];
    if(c1===c2){const step=r2>r1?1:-1;for(let r=r1;r!==r2;r+=step)pts.push([c1,r]);}
    else{const step=c2>c1?1:-1;for(let c=c1;c!==c2;c+=step)pts.push([c,r1]);}
  }
  pts.push(wps[wps.length-1]);
  return pts;
}

// 30 unique paths (grouped by difficulty)
const LEVEL_PATHS=[
  // 1-5: straight
  mkPath([[0,5],[15,5]]),
  mkPath([[0,3],[15,3]]),
  mkPath([[0,7],[15,7]]),
  mkPath([[0,5],[15,5]]),
  mkPath([[0,4],[15,4]]),
  // 6-10: L-shape
  mkPath([[0,2],[8,2],[8,9],[15,9]]),
  mkPath([[0,8],[7,8],[7,2],[15,2]]),
  mkPath([[0,5],[5,5],[5,2],[15,2]]),
  mkPath([[0,2],[10,2],[10,8],[15,8]]),
  mkPath([[0,8],[6,8],[6,3],[15,3]]),
  // 11-15: Z/S-shape
  mkPath([[0,2],[6,2],[6,5],[10,5],[10,9],[15,9]]),
  mkPath([[0,9],[5,9],[5,5],[11,5],[11,2],[15,2]]),
