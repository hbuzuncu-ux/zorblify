function spawnEnemy(type){
  const d=EDEFS[type];
  const [sc,sr]=path[0];
  enemies.push({id:eid++,type,hp:d.hp,maxHp:d.hp,x:sc*CELL+CELL/2,y:sr*CELL+CELL/2,
    spd:d.spd,baseSpd:d.spd,reward:d.reward,sz:d.sz,col:d.col,icon:d.icon,
    pidx:0,slowT:0,dead:false});
}
function updateEnemies(){
  for(const e of enemies){
    if(e.dead)continue;
    e.spd=frost?e.baseSpd*0.15:e.slowT>0?e.baseSpd*0.5:e.baseSpd;
    if(e.slowT>0)e.slowT--;
    if(e.pidx<path.length-1){
      const [tc,tr]=path[e.pidx+1];
      const tx=tc*CELL+CELL/2,ty=tr*CELL+CELL/2;
      const dx=tx-e.x,dy=ty-e.y,dist=Math.sqrt(dx*dx+dy*dy);
      if(dist<e.spd*2)e.pidx++;
      else{e.x+=dx/dist*e.spd;e.y+=dy/dist*e.spd;}
    }else{
      lives=Math.max(0,lives-1);
      e.dead=true;
      addFloat('💔 -1 Life',e.x,e.y,'#f87171');
      updateHUD();
      if(lives<=0){onLivesOut();return;}
    }
  }
  enemies=enemies.filter(e=>!e.dead);
}

// ═══════════════════════════════
// TOWERS
// ═══════════════════════════════
function getTStats(t){
  const b=TDEFS[t.type];
  if(t.level===1)return b;
  return{...b,...b.upg[t.level-2]};
}
function updateTowers(){
  for(const t of towers){
    const s=getTStats(t);
    t.ft=(t.ft||0)+1;
    if(t.ft<s.rate)continue;
    let tgt=null,bd=s.range*CELL;
    for(const e of enemies){
      if(e.dead)continue;
      const dx=e.x-t.x,dy=e.y-t.y,d=Math.sqrt(dx*dx+dy*dy);
      if(d<bd){bd=d;tgt=e;}
    }
    if(!tgt)continue;
    t.ft=0;
    projs.push({x:t.x,y:t.y,tid:tgt.id,type:t.type,dmg:s.dmg,aoe:s.aoe||0,slow:s.slow||0,
      spd:6,col:TDEFS[t.type].color,dead:false});
  }
}
function updateProjs(){
  for(const p of projs){
    if(p.dead)continue;
    const tgt=enemies.find(e=>e.id===p.tid&&!e.dead);
    if(!tgt){p.dead=true;continue;}
    const dx=tgt.x-p.x,dy=tgt.y-p.y,dist=Math.sqrt(dx*dx+dy*dy);
    if(dist<p.spd+4){
      if(p.aoe>0){
        for(const e of enemies){
          if(e.dead)continue;
          const d=Math.sqrt((e.x-tgt.x)**2+(e.y-tgt.y)**2);
          if(d<p.aoe*CELL){dealDmg(e,p.dmg*(d<8?1:0.55));spawnParts(e.x,e.y,'#f87171',5);}
        }
        spawnParts(tgt.x,tgt.y,'#fb923c',14);
      }else{dealDmg(tgt,p.dmg);if(p.slow>0)tgt.slowT=110;}
      p.dead=true;
    }else{p.x+=dx/dist*p.spd;p.y+=dy/dist*p.spd;}
  }
  projs=projs.filter(p=>!p.dead);
}
function dealDmg(e,dmg){
  e.hp-=dmg;
  if(e.hp<=0){
    e.dead=true;
    let rew=Math.round(e.reward*(goldRush?3:1)*combo);
    gold+=rew; score+=Math.round(e.reward*combo*10);
    addFloat('+'+rew+'💰',e.x,e.y-12,'#f0c060');
    spawnParts(e.x,e.y,e.col,10);
    combo=Math.min(5,combo+0.4); comboTimer=110;
    updateHUD(); updateShopAfford();
    if(combo>=2)showCombo();
  }
}

