<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Castle Defense — Zorblify</title>
<link href="https://fonts.googleapis.com/css2?family=MedievalSharp&family=Cinzel:wght@400;700;900&family=Crimson+Text:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --gold:#c9a84c; --gold2:#f0c060; --dark:#0a0804;
  --stone:#2a2018; --stone2:#3d3020; --grass:#1a2e0f;
  --grass2:#243d14; --path:#6b4a22; --path2:#8a6030;
  --red:#c0392b; --green:#27ae60; --blue:#2980b9;
  --purple:#8e44ad; --orange:#e67e22;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--dark);font-family:'Crimson Text',serif;color:#e8dcc8;overflow:hidden;height:100vh;display:flex;flex-direction:column;user-select:none;}

/* BACK */
.back-btn{position:fixed;top:10px;left:10px;z-index:999;background:rgba(201,168,76,0.15);color:var(--gold);text-decoration:none;padding:6px 12px;border-radius:6px;font-size:12px;font-weight:700;border:1px solid rgba(201,168,76,0.3);font-family:'Cinzel',serif;}
.back-btn:hover{background:rgba(201,168,76,0.25);}

/* SCREENS */
.screen{display:none;flex-direction:column;align-items:center;justify-content:center;width:100%;height:100vh;padding:20px;}
.screen.active{display:flex;}

/* MAIN MENU */
#mainMenu{background:radial-gradient(ellipse at center, #1a1208 0%, #0a0804 70%);}
.menu-title{font-family:'Cinzel',serif;font-size:52px;font-weight:900;color:var(--gold);text-shadow:0 0 40px rgba(201,168,76,0.6),0 4px 8px rgba(0,0,0,0.8);letter-spacing:4px;margin-bottom:6px;}
.menu-sub{font-family:'Crimson Text',serif;font-size:18px;color:#7a6a50;margin-bottom:40px;letter-spacing:3px;font-style:italic;}
.mode-row{display:flex;gap:20px;margin-bottom:32px;}
.mode-card{width:200px;background:rgba(255,255,255,0.03);border:1px solid rgba(201,168,76,0.2);border-radius:12px;padding:22px 16px;text-align:center;cursor:pointer;transition:all .2s;}
.mode-card:hover,.mode-card.sel{border-color:var(--gold);background:rgba(201,168,76,0.08);transform:translateY(-4px);box-shadow:0 8px 32px rgba(201,168,76,0.2);}
.mode-emoji{font-size:36px;margin-bottom:10px;}
.mode-name{font-family:'Cinzel',serif;font-size:14px;color:var(--gold);margin-bottom:6px;}
.mode-desc{font-size:12px;color:#5a4e38;line-height:1.5;}
.menu-btn{font-family:'Cinzel',serif;background:linear-gradient(135deg,#b8860b,var(--gold2));color:#1a1000;border:none;padding:14px 44px;border-radius:8px;font-size:16px;font-weight:700;cursor:pointer;letter-spacing:2px;box-shadow:0 4px 20px rgba(201,168,76,0.4);transition:all .15s;}
.menu-btn:hover{transform:translateY(-2px);box-shadow:0 8px 32px rgba(201,168,76,0.6);}
.menu-btn.sec{background:transparent;color:#7a6a50;border:1px solid #3a3020;box-shadow:none;margin-left:10px;}
.menu-btn.sec:hover{color:var(--gold);border-color:var(--gold);}

/* LEVEL SELECT */
#levelSelect{background:radial-gradient(ellipse at center,#1a1208 0%,#0a0804 70%);overflow-y:auto;}
.level-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:10px;max-width:640px;margin:20px 0;}
.lv-btn{aspect-ratio:1;border-radius:10px;border:1px solid #2a2010;background:rgba(255,255,255,0.03);cursor:pointer;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;transition:all .15s;font-family:'Cinzel',serif;}
.lv-btn:hover:not(.locked){border-color:var(--gold);background:rgba(201,168,76,0.1);transform:scale(1.05);}
.lv-btn.locked{opacity:0.3;cursor:not-allowed;}
.lv-btn.done{border-color:#27ae60;background:rgba(39,174,96,0.1);}
.lv-btn.sel{border-color:var(--gold);background:rgba(201,168,76,0.15);box-shadow:0 0 16px rgba(201,168,76,0.3);}
.lv-num{font-size:16px;font-weight:700;color:var(--gold);}
.lv-stars{font-size:9px;color:#f0c060;}

/* HUD */
#hud{height:48px;background:rgba(10,8,4,0.97);border-bottom:1px solid rgba(201,168,76,0.2);display:none;align-items:center;justify-content:space-between;padding:0 14px;flex-shrink:0;gap:8px;}
.hud-block{display:flex;align-items:center;gap:14px;}
.hud-item{text-align:center;min-width:44px;}
.hud-lbl{font-size:8px;color:#5a4e38;letter-spacing:1px;text-transform:uppercase;font-family:'Cinzel',serif;}
.hud-val{font-size:15px;font-weight:700;line-height:1.2;}
.hv-gold{color:var(--gold2);}
.hv-lives{color:#f87171;}
.hv-wave{color:#a78bfa;}
.hv-score{color:#4ade80;}
.hv-combo{color:#fb923c;}
.hv-level{color:var(--gold);}
.speed-btn{font-family:'Cinzel',serif;background:rgba(255,255,255,0.04);border:1px solid #2a2010;color:#7a6a50;padding:4px 10px;border-radius:6px;cursor:pointer;font-size:11px;transition:all .15s;}
.speed-btn.active{border-color:var(--gold);color:var(--gold);background:rgba(201,168,76,0.1);}
.pause-btn{font-family:'Cinzel',serif;background:rgba(255,255,255,0.04);border:1px solid #2a2010;color:#7a6a50;padding:4px 10px;border-radius:6px;cursor:pointer;font-size:11px;}
.pause-btn:hover{border-color:var(--gold);color:var(--gold);}
.lives-hearts{display:flex;gap:3px;font-size:14px;}

/* GAME AREA */
#gameArea{display:none;flex:1;overflow:hidden;position:relative;}
#gameCanvas{display:block;}

/* SHOP */
#shop{position:fixed;right:0;top:48px;bottom:56px;width:148px;background:rgba(10,8,4,0.97);border-left:1px solid rgba(201,168,76,0.15);padding:8px 6px;overflow-y:auto;display:none;flex-direction:column;gap:6px;z-index:30;}
.shop-hdr{font-family:'Cinzel',serif;font-size:9px;color:#5a4e38;letter-spacing:1px;text-align:center;text-transform:uppercase;margin:4px 0 2px;}
.t-btn{background:rgba(255,255,255,0.02);border:1px solid #2a2010;border-radius:8px;padding:8px 6px;cursor:pointer;transition:all .12s;text-align:center;}
.t-btn:hover{border-color:var(--gold);background:rgba(201,168,76,0.06);}
.t-btn.sel{border-color:var(--gold);background:rgba(201,168,76,0.12);box-shadow:0 0 10px rgba(201,168,76,0.2);}
.t-btn.cant{opacity:0.35;cursor:not-allowed;}
.t-icon{font-size:20px;margin-bottom:3px;}
.t-name{font-family:'Cinzel',serif;font-size:10px;font-weight:700;margin-bottom:1px;}
.t-cost{font-size:10px;color:var(--gold2);}
.t-desc{font-size:8px;color:#4a3e28;margin-top:2px;line-height:1.4;}
.shop-sep{height:1px;background:rgba(255,255,255,0.04);margin:2px 0;}
.t-info{font-size:9px;color:#4a3e28;text-align:center;line-height:1.6;padding:4px;}

/* SPELL BAR */
#spellBar{position:fixed;bottom:0;left:0;right:148px;height:56px;background:rgba(10,8,4,0.97);border-top:1px solid rgba(201,168,76,0.15);display:none;align-items:center;padding:0 14px;gap:16px;z-index:30;}
.spell-wrap{display:flex;align-items:center;gap:10px;}
.sp-btn{display:flex;flex-direction:column;align-items:center;gap:2px;cursor:pointer;}
.sp-box{width:40px;height:40px;border-radius:8px;border:1px solid #3a3020;background:rgba(255,255,255,0.03);display:flex;align-items:center;justify-content:center;font-size:18px;position:relative;transition:all .15s;}
.sp-box.rdy{border-color:var(--gold);box-shadow:0 0 12px rgba(201,168,76,0.35);}
.sp-box.cd{opacity:0.45;}
.sp-cd{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.55);border-radius:8px;font-size:9px;color:#888;font-family:'Cinzel',serif;}
.sp-lbl{font-size:8px;color:#4a3e28;font-family:'Cinzel',serif;letter-spacing:0.5px;}
.spell-info{font-size:10px;color:#4a3e28;line-height:1.6;}

/* OVERLAYS */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,0.82);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:200;backdrop-filter:blur(3px);}
.ov-icon{font-size:64px;margin-bottom:12px;}
.ov-title{font-family:'Cinzel',serif;font-size:28px;font-weight:900;color:var(--gold);margin-bottom:8px;text-shadow:0 0 20px rgba(201,168,76,0.5);}
.ov-info{font-size:15px;color:#7a6a50;margin-bottom:24px;text-align:center;line-height:1.8;font-style:italic;}
.ov-btns{display:flex;gap:10px;}

/* WAVE ANNOUNCE */
#waveAnn{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);font-family:'Cinzel',serif;font-size:26px;font-weight:900;color:var(--gold);text-shadow:0 0 30px rgba(201,168,76,0.8);pointer-events:none;z-index:150;opacity:0;transition:opacity .4s;}

/* COMBO */
#comboPop{position:fixed;top:40%;left:50%;transform:translate(-50%,-50%);font-family:'Cinzel',serif;font-size:28px;font-weight:900;color:#fb923c;text-shadow:0 0 24px rgba(251,146,60,0.9);pointer-events:none;z-index:150;opacity:0;}

/* FLOAT TEXT */
@keyframes floatUp{0%{transform:translateY(0);opacity:1}100%{transform:translateY(-52px);opacity:0}}
.ft{position:fixed;pointer-events:none;z-index:140;font-weight:700;animation:floatUp 1s ease forwards;font-family:'Cinzel',serif;}

/* CONFETTI */
@keyframes cfFall{0%{transform:translateY(-20px) rotate(0);opacity:1}100%{transform:translateY(110vh) rotate(720deg);opacity:0}}
.cf{position:fixed;pointer-events:none;z-index:160;border-radius:2px;animation:cfFall linear forwards;}

/* SCOREBOARD */
#scoreboardScreen{background:radial-gradient(ellipse at center,#1a1208 0%,#0a0804 70%);}
.sb-table{width:100%;max-width:440px;border-collapse:collapse;margin:16px 0;}
.sb-table th{font-family:'Cinzel',serif;font-size:11px;color:#5a4e38;padding:6px 12px;text-align:left;border-bottom:1px solid #2a2010;letter-spacing:1px;}
