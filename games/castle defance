  mkPath([[0,2],[5,2],[5,6],[11,6],[11,2],[15,2]]),
  // 16-20: U/spiral
  mkPath([[0,1],[13,1],[13,5],[3,5],[3,9],[15,9]]),
  mkPath([[0,9],[12,9],[12,5],[4,5],[4,1],[15,1]]),
