.sb-me td{background:rgba(201,168,76,0.08);color:var(--gold);}
.medal{font-size:16px;}

/* SCROLLBAR */
::-webkit-scrollbar{width:4px;}
::-webkit-scrollbar-track{background:#0a0804;}
::-webkit-scrollbar-thumb{background:#2a2010;border-radius:2px;}
</style>
</head>
