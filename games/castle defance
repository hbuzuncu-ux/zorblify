function castSpell(spell){
  if(spellCDs[spell]>0)return;
  spellCDs[spell]=SPELL_CD[spell];
  if(spell==='meteor'){
    for(const e of enemies){if(!e.dead&&Math.random()<0.75){dealDmg(e,220);spawnParts(e.x,e.y,'#fb923c',14);}}
    addFloat('☄️ METEOR!',CW/2,CH/3,'#fb923c',true);
  }else if(spell==='frost'){
    frost=true; frostT=300;
    addFloat('❄️ FROST!',CW/2,CH/3,'#93c5fd',true);
  }else if(spell==='goldrush'){
    goldRush=true; goldRushT=600;
    addFloat('💰 GOLD RUSH!',CW/2,CH/3,'#f0c060',true);
  }
}
function tickSpells(){
  if(comboTimer>0){comboTimer--;}else if(combo>1){combo=1;updateHUD();}
  if(goldRushT>0)goldRushT--;else goldRush=false;
  if(frostT>0)frostT--;else frost=false;
  ['meteor','frost','goldrush'].forEach(s=>{
    if(spellCDs[s]>0)spellCDs[s]--;
    const el=document.getElementById('sp-'+s);
    const cd=document.getElementById('cd-'+s);
    if(spellCDs[s]>0){
      el.classList.remove('rdy');el.classList.add('cd');
      cd.style.display='flex';cd.textContent=Math.ceil(spellCDs[s]/60)+'s';
    }else{
      el.classList.add('rdy');el.classList.remove('cd');cd.style.display='none';
    }
  });
}

