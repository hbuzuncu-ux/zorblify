  // 21-25: snake/complex
  mkPath([[0,1],[6,1],[6,4],[2,4],[2,7],[8,7],[8,4],[12,4],[12,9],[15,9]]),
  mkPath([[0,9],[5,9],[5,6],[1,6],[1,3],[9,3],[9,7],[13,7],[13,3],[15,3]]),
  mkPath([[0,2],[4,2],[4,6],[8,6],[8,2],[12,2],[12,8],[15,8]]),
  mkPath([[0,8],[3,8],[3,4],[7,4],[7,8],[11,8],[11,2],[15,2]]),
