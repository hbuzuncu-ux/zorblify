// Endless path — complex S
const ENDLESS_PATH=mkPath([[0,1],[4,1],[4,4],[1,4],[1,7],[5,7],[5,4],[9,4],[9,8],[13,8],[13,3],[15,3]]);

// Wave definitions per level
function mkWaves(level){
  const waves=[];
  for(let w=1;w<=6;w++){
    const q=[];
    const difficulty=level+w*0.5;
    if(difficulty<4){
      for(let i=0;i<Math.ceil(difficulty*1.3);i++)q.push('goblin');
    }else if(difficulty<8){
      for(let i=0;i<Math.ceil(difficulty*1.2);i++)q.push('goblin');
      for(let i=0;i<Math.ceil(difficulty*0.6);i++)q.push('zombie');
    }else if(difficulty<14){
      for(let i=0;i<Math.ceil(difficulty*0.8);i++)q.push('zombie');
      for(let i=0;i<Math.ceil(difficulty*0.5);i++)q.push('knight');
      if(w>=5)for(let i=0;i<2;i++)q.push('troll');
    }else if(difficulty<22){
      for(let i=0;i<Math.ceil(difficulty*0.5);i++)q.push('zombie');
      for(let i=0;i<Math.ceil(difficulty*0.5);i++)q.push('knight');
      for(let i=0;i<Math.ceil(difficulty*0.2);i++)q.push('troll');
      if(w===6&&level%5===0)q.push('boss');
    }else{
      for(let i=0;i<Math.ceil(difficulty*0.4);i++)q.push('knight');
      for(let i=0;i<Math.ceil(difficulty*0.3);i++)q.push('troll');
      if(w>=5)q.push('boss');
    }
    // shuffle
    for(let i=q.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[q[i],q[j]]=[q[j],q[i]];}
    waves.push({queue:q,interval:Math.max(35,100-level*2-w*3)});
  }
  return waves;
}

