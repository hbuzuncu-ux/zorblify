// ═══════════════════════════════
// RENDER
// ═══════════════════════════════
function render(){
  ctx.clearRect(0,0,CW,CH);
  // Grass
  ctx.fillStyle='#1a2e0f';
  ctx.fillRect(0,0,CW,CH);
  // Grid lines
  ctx.strokeStyle='rgba(0,0,0,0.1)';ctx.lineWidth=1;
  for(let c=0;c<=COLS;c++){ctx.beginPath();ctx.moveTo(c*CELL,0);ctx.lineTo(c*CELL,CH);ctx.stroke();}
  for(let r=0;r<=ROWS;r++){ctx.beginPath();ctx.moveTo(0,r*CELL);ctx.lineTo(CW,r*CELL);ctx.stroke();}
  drawPath();
  // Hover
  if(hoverCell){
    const{col:hc,row:hr}=hoverCell;
    if(!pathSet.has(hc+','+hr)&&!towers.find(t=>t.col===hc&&t.row===hr)){
      ctx.fillStyle='rgba(201,168,76,0.12)';
      ctx.fillRect(hc*CELL,hr*CELL,CELL,CELL);
      ctx.strokeStyle='rgba(201,168,76,0.4)';ctx.lineWidth=1;
      ctx.strokeRect(hc*CELL,hr*CELL,CELL,CELL);
    }
  }
  // Selected tower range
  if(selCell){
    const t=towers.find(t=>t.col===selCell.col&&t.row===selCell.row);
    if(t){
      const s=getTStats(t);
      ctx.beginPath();ctx.arc(t.x,t.y,s.range*CELL,0,Math.PI*2);
      ctx.strokeStyle='rgba(255,255,255,0.12)';ctx.lineWidth=1;
      ctx.setLineDash([4,4]);ctx.stroke();ctx.setLineDash([]);
    }
  }
  drawTowers();
  drawEnemies();
  drawProjs();
  // Particles
  ctx.save();
  for(const p of parts){
    ctx.globalAlpha=p.life;ctx.fillStyle=p.col;
    ctx.beginPath();ctx.arc(p.x,p.y,p.r*p.life,0,Math.PI*2);ctx.fill();
  }
  ctx.restore();
  // Castle at end
  const[lc,lr]=path[path.length-1];
  ctx.font='28px serif';ctx.textAlign='center';ctx.textBaseline='middle';
  ctx.fillText('🏰',lc*CELL+CELL/2,lr*CELL+CELL/2);
  // Start arrow
  const[sc,sr]=path[0];
  ctx.fillStyle='rgba(255,255,255,0.25)';ctx.font='bold 13px Arial';
  ctx.textAlign='center';ctx.textBaseline='middle';
  ctx.fillText('►',sc*CELL+CELL/2,sr*CELL+CELL/2);
  // Frost overlay
  if(frost){ctx.fillStyle='rgba(147,197,253,0.07)';ctx.fillRect(0,0,CW,CH);}
}
function drawPath(){
  for(const[c,r]of path){
    ctx.fillStyle='#6b4a22';ctx.fillRect(c*CELL,c*CELL>0||r*CELL>0?r*CELL:r*CELL,CELL,CELL);
    ctx.fillStyle='#7a5528';
    const idx=path.findIndex(([pc,pr])=>pc===c&&pr===r);
    if(idx%2===0){ctx.fillRect(c*CELL+2,r*CELL+2,CELL/2-2,CELL/2-2);ctx.fillRect(c*CELL+CELL/2,r*CELL+CELL/2,CELL/2-2,CELL/2-2);}
    else{ctx.fillRect(c*CELL+CELL/2,r*CELL+2,CELL/2-2,CELL/2-2);ctx.fillRect(c*CELL+2,r*CELL+CELL/2,CELL/2-2,CELL/2-2);}
    ctx.strokeStyle='rgba(0,0,0,0.3)';ctx.lineWidth=1;ctx.strokeRect(c*CELL,r*CELL,CELL,CELL);
  }
}
function drawTowers(){
  for(const t of towers){
    const sel=selCell&&selCell.col===t.col&&selCell.row===t.row;
    ctx.fillStyle=sel?'rgba(201,168,76,0.25)':'rgba(0,0,0,0.45)';
    ctx.strokeStyle=sel?'#c9a84c':TDEFS[t.type].color+'77';
    ctx.lineWidth=sel?2:1;
    ctx.beginPath();ctx.roundRect(t.col*CELL+3,t.row*CELL+3,CELL-6,CELL-6,6);
    ctx.fill();ctx.stroke();
    ctx.font=Math.floor(CELL*0.52)+'px serif';ctx.textAlign='center';ctx.textBaseline='middle';
    ctx.fillText(TDEFS[t.type].icon,t.x,t.y);
    if(t.level>1){
      ctx.fillStyle='#f0c060';ctx.font='9px serif';
      ctx.fillText('★'.repeat(t.level),t.x,t.row*CELL+CELL-5);
    }
  }
}
function drawEnemies(){
  for(const e of enemies){
    if(e.dead)continue;
    ctx.fillStyle='rgba(0,0,0,0.25)';
    ctx.beginPath();ctx.ellipse(e.x,e.y+e.sz*0.7,e.sz*0.55,e.sz*0.18,0,0,Math.PI*2);ctx.fill();
    const bw=e.sz*2,bh=4,hp=e.hp/e.maxHp;
    ctx.fillStyle='#1a1a1a';ctx.fillRect(e.x-bw/2,e.y-e.sz-7,bw,bh);
    ctx.fillStyle=hp>0.5?'#27ae60':hp>0.25?'#f39c12':'#e74c3c';
    ctx.fillRect(e.x-bw/2,e.y-e.sz-7,bw*hp,bh);
    ctx.font=e.sz+'px serif';ctx.textAlign='center';ctx.textBaseline='middle';
    ctx.fillText(e.icon,e.x,e.y);
    if(frost||e.slowT>0){
      ctx.fillStyle='rgba(147,197,253,0.28)';ctx.beginPath();ctx.arc(e.x,e.y,e.sz*0.65,0,Math.PI*2);ctx.fill();
    }
  }
}
function drawProjs(){
  for(const p of projs){
    if(p.dead)continue;
    ctx.shadowColor=p.col;ctx.shadowBlur=7;
    ctx.fillStyle=p.col;
    ctx.beginPath();ctx.arc(p.x,p.y,p.type==='cannon'?5:2.5,0,Math.PI*2);ctx.fill();
    ctx.shadowBlur=0;
  }
}

// ═══════════════════════════════
// MAIN LOOP
// ═══════════════════════════════
function gameLoop(){
  frameId=requestAnimationFrame(gameLoop);
  if(!gameActive)return;
  if(paused){render();return;}
  const steps=Math.round(gameSpeed);
  for(let s=0;s<steps;s++){
    if(spawnQueue.length>0&&waveActive){
      spawnTimer++;
      if(spawnTimer>=Math.round(spawnInterval/gameSpeed)){
        spawnTimer=0;spawnEnemy(spawnQueue.shift());
      }
    }
    updateEnemies();
    updateTowers();
    updateProjs();
    tickSpells();
    for(let i=parts.length-1;i>=0;i--){
      const p=parts[i];p.x+=p.vx;p.y+=p.vy;p.vy+=0.1;p.life-=p.dec;
      if(p.life<=0)parts.splice(i,1);
    }
    // Wave clear check
    if(waveActive&&spawnQueue.length===0&&enemies.length===0){
      waveActive=false;
      const bonus=Math.round(waveIdx*18*(gMode==='campaign'?Math.max(1,gLevel*0.5):1));
      gold+=bonus;score+=waveIdx*80;
      addFloat('Wave '+waveIdx+' Clear! +'+bonus+'💰',CW/2,CH/2,'#f0c060',true);
      updateHUD();updateShopAfford();
      if(gMode==='campaign'&&waveIdx>=6){
        setTimeout(onLevelComplete,1600);
      }else if(gMode==='endless'||waveIdx<6){
        setTimeout(startWave,2200);
      }
    }
  }
  render();
}

// ═══════════════════════════════
// WIN / FAIL
// ═══════════════════════════════
function onLevelComplete(){
  gameActive=false;
  progress[gLevel]=1;
  localStorage.setItem('cd_progress',JSON.stringify(progress));
  showOverlay('🏆','Level '+gLevel+' Complete!',
    'Score: <b>'+score+'</b><br>Waves: 6/6',
    [{label:'Next Level →',fn:()=>{hideOverlay();if(gLevel<30)startCampaignLevel(gLevel+1);else showScreen('mainMenu');}},
     {label:'Levels',fn:()=>{hideOverlay();openLevelSelect();},sec:true}]);
}
function onLivesOut(){
  gameActive=false;
  if(gMode==='campaign'){
    showOverlay('💀','Level Failed!',
      'You lost all lives on Wave '+waveIdx,
      [{label:'Retry →',fn:()=>{hideOverlay();startCampaignLevel(gLevel);}},
       {label:'Levels',fn:()=>{hideOverlay();openLevelSelect();},sec:true}]);
  }else{
    pendingEndlessScore={wave:waveIdx,score};
    document.getElementById('nmTitle').textContent='Endless — Wave '+waveIdx;
    document.getElementById('nmInfo').textContent='Score: '+score+' · Submit to leaderboard?';
    document.getElementById('nmInput').value=localStorage.getItem('cd_name')||'';
    document.getElementById('nameModal').style.display='flex';
  }
}
async function submitEndlessScore(){
  const name=document.getElementById('nmInput').value.trim();
  if(name.length>=2){
    localStorage.setItem('cd_name',name);
    await saveEndlessScore(name,pendingEndlessScore.wave,pendingEndlessScore.score);
  }
  closeNameModal();
}
function closeNameModal(){
  document.getElementById('nameModal').style.display='none';
  showScreen('mainMenu');
}

// ═══════════════════════════════
// OVERLAY HELPER
// ═══════════════════════════════
let ovEl=null;
function showOverlay(icon,title,info,btns){
  if(ovEl)ovEl.remove();
  ovEl=document.createElement('div');
  ovEl.className='overlay';
  ovEl.innerHTML=`<div class="ov-icon">${icon}</div><div class="ov-title">${title}</div><div class="ov-info">${info}</div><div class="ov-btns">${btns.map(b=>`<button class="menu-btn ${b.sec?'sec':''}" onclick="(${b.fn.toString()})()">${b.label}</button>`).join('')}</div>`;
  document.body.appendChild(ovEl);
}
function hideOverlay(){if(ovEl){ovEl.remove();ovEl=null;}}

// ═══════════════════════════════
// SHOP & SELECTION
// ═══════════════════════════════
function selTower(type){
  selTowerType=type;selCell=null;
  ['archer','mage','cannon'].forEach(t=>{
    document.getElementById('tb-'+t).classList.toggle('sel',t===type);
  });
  document.getElementById('tInfo').textContent='Click empty cell to place';
  document.getElementById('upgCost').textContent='—';
  document.getElementById('sellVal').textContent='—';
}
function doUpgrade(){
  if(!selCell)return;
  const t=towers.find(t=>t.col===selCell.col&&t.row===selCell.row);
  if(!t||t.level>=3){addFloat('Max Level!',CW/2,CH/2,'#f87171');return;}
  const cost=TDEFS[t.type].cost*(t.level+1);
  if(gold<cost){addFloat('Not enough gold!',CW/2,200,'#f87171');return;}
  gold-=cost;t.level++;
  spawnParts(t.x,t.y,'#f0c060',10);
  addFloat('⬆️ Upgraded!',t.x,t.y-20,'#4ade80');
  updateHUD();updateShopAfford();updateTowerInfo(t);
}
function doSell(){
  if(!selCell)return;
  const idx=towers.findIndex(t=>t.col===selCell.col&&t.row===selCell.row);
  if(idx<0)return;
  const t=towers[idx];
  let tc=TDEFS[t.type].cost;
  for(let i=1;i<t.level;i++)tc+=TDEFS[t.type].cost*(i+1);
  const ref=Math.round(tc*0.6);
  gold+=ref;addFloat('+'+ref+'💰 Sold',t.x,t.y,'#f0c060');
  towers.splice(idx,1);selCell=null;
  updateHUD();updateShopAfford();
  document.getElementById('tInfo').textContent='Click empty cell to place';
  document.getElementById('upgCost').textContent='—';
  document.getElementById('sellVal').textContent='—';
}
function updateTowerInfo(t){
  const s=getTStats(t);
  document.getElementById('tInfo').innerHTML=`${TDEFS[t.type].name} Lv${t.level}<br>DMG:${s.dmg} RNG:${s.range}<br>Rate:${(60/s.rate).toFixed(1)}/s`;
  document.getElementById('upgCost').textContent=t.level<3?'💰 '+(TDEFS[t.type].cost*(t.level+1)):'Max';
  document.getElementById('sellVal').textContent='💰 '+Math.round(TDEFS[t.type].cost*t.level*0.6);
}
function updateShopAfford(){
  ['archer','mage','cannon'].forEach(t=>{
    document.getElementById('tb-'+t).classList.toggle('cant',TDEFS[t].cost>gold);
  });
}

// ═══════════════════════════════
// HUD
// ═══════════════════════════════
function updateHUD(){
  document.getElementById('hHdGold').textContent=gold;
  const lh=document.getElementById('hHdLives');
  lh.innerHTML='';
  const maxL=gMode==='campaign'?3:5;
  for(let i=0;i<maxL;i++){
    const s=document.createElement('span');
    s.textContent=i<lives?'❤️':'🖤';s.style.fontSize='13px';
    lh.appendChild(s);
  }
  document.getElementById('hHdScore').textContent=score;
  document.getElementById('hHdCombo').textContent='×'+combo.toFixed(1);
}

// ═══════════════════════════════
// INPUT
// ═══════════════════════════════
function onCanvasClick(e){
  if(!gameActive||paused)return;
  const rect=canvas.getBoundingClientRect();
  const sx=CW/rect.width,sy=CH/rect.height;
  const mx=(e.clientX-rect.left)*sx,my=(e.clientY-rect.top)*sy;
  const col=Math.floor(mx/CELL),row=Math.floor(my/CELL);
  if(col<0||col>=COLS||row<0||row>=ROWS)return;
  const ex=towers.find(t=>t.col===col&&t.row===row);
  if(ex){
    selCell={col,row};
    selTowerType=ex.type;
    ['archer','mage','cannon'].forEach(t=>document.getElementById('tb-'+t).classList.remove('sel'));
    document.getElementById('tb-'+ex.type).classList.add('sel');
    updateTowerInfo(ex);
    return;
  }
  if(pathSet.has(col+','+row)){addFloat('Cannot build on path!',mx+48,my+52,'#f87171');return;}
  const td=TDEFS[selTowerType];
  if(gold<td.cost){addFloat('Not enough gold!',mx+48,my+52,'#f87171');return;}
  gold-=td.cost;
  towers.push({col,row,type:selTowerType,level:1,ft:0,x:col*CELL+CELL/2,y:row*CELL+CELL/2});
  selCell=null;
  updateHUD();updateShopAfford();
}
function onCanvasMove(e){
  const rect=canvas.getBoundingClientRect();
  const sx=CW/rect.width,sy=CH/rect.height;
  const mx=(e.clientX-rect.left)*sx,my=(e.clientY-rect.top)*sy;
  const col=Math.floor(mx/CELL),row=Math.floor(my/CELL);
  hoverCell=(col>=0&&col<COLS&&row>=0&&row<ROWS)?{col,row}:null;
}
function setSpeed(s){
  gameSpeed=s;
  document.getElementById('sp1').classList.toggle('active',s===1);
  document.getElementById('sp2').classList.toggle('active',s===2);
}
function togglePause(){
  paused=!paused;
  document.getElementById('pauseBtn').textContent=paused?'▶':'⏸';
}
</script>
