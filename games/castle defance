// WAVE SYSTEM
// ═══════════════════════════════
function startWave(){
  waveIdx++;
  waveActive=true; betweenWaves=false;
  document.getElementById('hHdWave').textContent=waveIdx+'/'+(gMode==='endless'?'∞':6);
  if(gMode==='campaign'){
    const w=levelWaves[waveIdx-1];
    spawnQueue=[...w.queue];
    spawnInterval=w.interval;
  }else{
    spawnQueue=buildEndlessWave(waveIdx);
    spawnInterval=Math.max(28,95-waveIdx*2);
  }
  spawnTimer=0;
  announceWave();
}
function buildEndlessWave(w){
  const q=[];
  const n=Math.floor(w*1.8)+4;
  for(let i=0;i<n;i++){
    const r=Math.random();
    if(r<0.35)q.push('goblin');
    else if(r<0.6)q.push('zombie');
    else if(r<0.78)q.push('knight');
    else if(r<0.92)q.push('troll');
    else q.push('boss');
  }
  if(w%5===0)q.push('boss');
  for(let i=q.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[q[i],q[j]]=[q[j],q[i]];}
  return q;
}
function announceWave(){
  const el=document.getElementById('waveAnn');
  el.textContent='⚔️ Wave '+waveIdx+(gMode==='campaign'?' / 6':'');
  el.style.opacity='1';
  setTimeout(()=>{el.style.opacity='0';},1800);
}

